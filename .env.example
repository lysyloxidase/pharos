# PHAROS Environment Configuration
# Copy to .env and adjust values as needed.

# Ollama
PHAROS_OLLAMA_HOST=http://localhost:11434

# Neo4j
PHAROS_NEO4J_URI=bolt://localhost:7687
PHAROS_NEO4J_USER=neo4j
PHAROS_NEO4J_PASSWORD=pharos-dev

# Models (override defaults from config.py)
# PHAROS_MODEL_ROUTER=llama3.2:3b
# PHAROS_MODEL_EXTRACTOR=llama3.1:8b
# PHAROS_MODEL_VERIFIER=phi4:14b
# PHAROS_MODEL_REASONER=llama3.3:70b
# PHAROS_MODEL_CODER=qwen2.5-coder:32b
# PHAROS_EMBEDDING_MODEL=all-minilm:l6-v2
